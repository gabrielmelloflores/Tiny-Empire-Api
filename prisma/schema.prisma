datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
  roles    Role[] @default([PLAYER])

  players Player[]
}

model Match {
  id              Int         @id @default(autoincrement())
  name            String
  status          StatusMatch @default(waiting)
  turn            Int         @default(1)
  currentPlayerId Int?
  maxPlayers      Int
  createdAt       DateTime    @default(now())

  players       Player[] @relation("MatchPlayers")
  cities        City[]
  currentPlayer Player?  @relation("CurrentMatchPlayer", fields: [currentPlayerId], references: [id])
}

model Player {
  id      Int     @id @default(autoincrement())
  userId  Int
  matchId Int
  faction Faction

  score Int @default(0)
  gold  Int @default(0)
  food  Int @default(0)
  iron  Int @default(0)

  isEliminated Boolean @default(false)
  turnOrder    Int     @default(1)

  cities City[]

  user           User    @relation(fields: [userId], references: [id])
  match          Match   @relation("MatchPlayers", fields: [matchId], references: [id])
  currentInMatch Match[] @relation("CurrentMatchPlayer")

  @@index([userId])
  @@index([matchId])
}

model City {
  id            Int      @id @default(autoincrement())
  name          String
  matchId       Int
  ownerPlayerId Int?
  type          CityType

  defense   Int      @default(0)
  isCapital Boolean  @default(false)
  createdAt DateTime @default(now())

  match Match   @relation(fields: [matchId], references: [id])
  owner Player? @relation(fields: [ownerPlayerId], references: [id])

  buildings Building[]

  connectionsFrom CityConnection[] @relation("fromCity")
  connectionsTo   CityConnection[] @relation("toCity")

  @@index([matchId])
  @@index([ownerPlayerId])
}

model Building {
  id        Int          @id @default(autoincrement())
  cityId    Int
  type      BuildingType
  level     Int          @default(1)
  createdAt DateTime     @default(now())

  city City @relation(fields: [cityId], references: [id])

  @@unique([cityId, type])
  @@index([cityId])
}

model CityConnection {
  id         Int @id @default(autoincrement())
  fromCityId Int
  toCityId   Int

  fromCity City @relation("fromCity", fields: [fromCityId], references: [id])
  toCity   City @relation("toCity", fields: [toCityId], references: [id])

  @@unique([fromCityId, toCityId])
  @@index([fromCityId])
  @@index([toCityId])
}

enum Role {
  PLAYER
  ADMIN
}

enum StatusMatch {
  waiting
  running
  finished
}

enum Faction {
  HUMAN
  DWARF
  ELF
  UNDEAD
}

enum CityType {
  CAPITAL
  FORTRESS
  FARM_SETTLEMENT
  MINING_TOWN
  MARKET_TOWN
  RUINS
}

enum BuildingType {
  FARM
  MINE
  MARKET
  BARRACKS
  WALL
}
