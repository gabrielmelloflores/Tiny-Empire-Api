// Prisma schema for Tiny Empires API
// see https://www.prisma.io/docs/concepts/components/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// user account model
model User {
  id       Int     @id @default(autoincrement())
  username String  @unique
  password String
  roles    Role[]  @default([PLAYER])
  // relations
  matches  Player[]
}

model Match {
  id              Int         @id @default(autoincrement())
  name            String
  status          StatusMatch @default(waiting)
  turn            Int         @default(1)
  currentPlayerId Int?
  maxPlayers      Int
  createdAt       DateTime    @default(now())

  players         Player[]    @relation("MatchPlayers")
  currentPlayer   Player?     @relation("CurrentMatchPlayer", fields: [currentPlayerId], references: [id])
}

model Player {
  id            Int      @id @default(autoincrement())
  userId        Int
  matchId       Int
  score         Int      @default(0)
  gold          Int      @default(0)
  food          Int      @default(0)
  isEliminated  Boolean  @default(false)
  turnOrder     Int      @default(1)

  user          User     @relation(fields: [userId], references: [id])
  match         Match    @relation("MatchPlayers", fields: [matchId], references: [id])

  currentInMatch Match[] @relation("CurrentMatchPlayer")
}

enum Role {
  PLAYER
  ADMIN
}

enum StatusMatch {
  waiting
  running
  finished
}
